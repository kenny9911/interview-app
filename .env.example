# ──────────────────────────────────────────────────────────────────────────
# viva — environment template.  Copy to `.env` and fill in real values.
# NOTHING here is committed; `.env` is gitignored.
# The backend API and the LiveKit agent worker both read these.
# ──────────────────────────────────────────────────────────────────────────

# ── LiveKit (realtime media) ── REQUIRED for live audio/video ──────────────
# From your LiveKit Cloud project (or self-hosted server).
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── LLM provider selection ─────────────────────────────────────────────────
# Which provider backs the four-agent brain. One of: anthropic | openai | gemini | openrouter.
# Models are configured PER ROLE (planner / interviewer / reviewer / analyst) below;
# only the SELECTED provider's API key is required.
LLM_PROVIDER=anthropic

# ── LLM: Anthropic / Claude ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL_PLANNER=claude-opus-4-8
CLAUDE_MODEL_INTERVIEWER=claude-sonnet-4-6
CLAUDE_MODEL_REVIEWER=claude-opus-4-8
CLAUDE_MODEL_ANALYST=claude-opus-4-8

# ── LLM: OpenAI / GPT (native OpenAI-compatible API) ───────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_PLANNER=gpt-5.4
OPENAI_MODEL_INTERVIEWER=gpt-5.4-mini
OPENAI_MODEL_REVIEWER=gpt-5.4
OPENAI_MODEL_ANALYST=gpt-5.4

# ── LLM: Gemini (Google's OpenAI-compatibility endpoint) ───────────────────
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL_PLANNER=gemini-3.1-pro-preview
GEMINI_MODEL_INTERVIEWER=gemini-3-flash-preview
GEMINI_MODEL_REVIEWER=gemini-3.1-pro-preview
GEMINI_MODEL_ANALYST=gemini-3.1-pro-preview

# ── LLM: OpenRouter (OpenAI-compatible aggregator; namespaced model ids) ───
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PLANNER=google/gemini-3.1-pro-preview
OPENROUTER_MODEL_INTERVIEWER=google/gemini-3-flash-preview
OPENROUTER_MODEL_REVIEWER=google/gemini-3.1-pro-preview
OPENROUTER_MODEL_ANALYST=google/gemini-3.1-pro-preview

# ── Speech-to-text (streaming) ── REQUIRED for voice ───────────────────────
DEEPGRAM_API_KEY=

# ── Text-to-speech (streaming) ── REQUIRED for voice ───────────────────────
# Use one. Cartesia is the default in the agent; ElevenLabs supported as fallback.
CARTESIA_API_KEY=
ELEVENLABS_API_KEY=

# ── Voice pipeline tuning (agent worker) ── all OPTIONAL; sensible defaults ──
# Models (override only if the provider has a newer id).
DEEPGRAM_MODEL=nova-3
CARTESIA_MODEL=sonic-3
# Distinct Cartesia voice id per interviewer persona (omit → plugin default).
CARTESIA_VOICE_ARIA=
CARTESIA_VOICE_SAM=
CARTESIA_VOICE_LENA=
# Semantic end-of-turn detector: 'v1-mini' (local, no cloud), 'v1' (LiveKit Cloud), 'vad'/'off'.
TURN_DETECTOR=v1-mini
# Background-noise cancellation: 'bvc' (LiveKit Cloud, removes background voices),
# 'standard', 'telephony', or 'off'. Needs @livekit/noise-cancellation-node installed.
NOISE_CANCELLATION=bvc
# Emit structured `[voice-metrics]` log lines to fine-tune the pipeline (grep voice-metrics | jq).
LOG_METRICS=true
# VAD (Silero) — milliseconds / 0..1 threshold. Lower silence = faster turns/barge-in;
# raise activation in noisy rooms, lower it for soft talkers.
VAD_MIN_SPEECH_MS=50
VAD_MIN_SILENCE_MS=300
VAD_PREFIX_PADDING_MS=300
VAD_ACTIVATION_THRESHOLD=0.5
# Endpointing patience per style (ms). minDelay = floor before a turn can end
# (prevents clipping fast talkers); maxDelay = hard cap so the orb never hangs.
ENDPOINT_MIN_DELAY_MS_FRIENDLY=700
ENDPOINT_MAX_DELAY_MS_FRIENDLY=4000
ENDPOINT_MIN_DELAY_MS_BALANCED=500
ENDPOINT_MAX_DELAY_MS_BALANCED=3000
ENDPOINT_MIN_DELAY_MS_TOUGH=350
ENDPOINT_MAX_DELAY_MS_TOUGH=2000
# Barge-in discipline per style. minDuration (ms) + minWords gate out coughs/echo;
# falseInterruption settings let the agent resume if the "interruption" was noise.
INTERRUPT_MIN_DURATION_MS_FRIENDLY=300
INTERRUPT_MIN_WORDS_FRIENDLY=2
INTERRUPT_MIN_DURATION_MS_BALANCED=250
INTERRUPT_MIN_WORDS_BALANCED=1
INTERRUPT_MIN_DURATION_MS_TOUGH=200
INTERRUPT_MIN_WORDS_TOUGH=1

# ── Multi-language (i18n) ── per-language voice/ASR (agent worker) ──────────────
# The server pins the session's canonical locale (en | zh-Hans | zh-Hant | ja | ko)
# on the room metadata; the agent maps it to vendor codes here. All OPTIONAL with
# sensible defaults — EXCEPT the per-language voice ids: a non-English session
# REFUSES to use the English voice (no "awkward-foreigner" voice), so provision a
# native voice per (persona × language) before that language goes live.
# Native-recorded Cartesia voice ids per persona, per spoken language.
#   Mandarin (zh-Hans + zh-Hant) — REQUIRED before Simplified/Traditional ship:
CARTESIA_VOICE_ARIA_ZH=
CARTESIA_VOICE_SAM_ZH=
CARTESIA_VOICE_LENA_ZH=
#   Japanese (Phase 3): CARTESIA_VOICE_ARIA_JA= / _SAM_JA= / _LENA_JA=
#   Korean (Phase 4) is ElevenLabs, not Cartesia: ELEVENLABS_VOICE_ARIA_KO= etc.
# Deepgram STT language code per locale (defaults shown).
STT_LANG_EN=en-US
STT_LANG_ZH_HANS=zh-CN
STT_LANG_ZH_HANT=zh-TW
STT_LANG_JA=ja
STT_LANG_KO=ko
# Cartesia/TTS ISO language per spoken language (zh-Hans & zh-Hant both → zh).
TTS_LANG_EN=en
TTS_LANG_ZH=zh
TTS_LANG_JA=ja
TTS_LANG_KO=ko
# Deepgram STT endpointing (ms): a little longer for CJK so a clause-pause doesn't
# end the turn early.
DEEPGRAM_ENDPOINTING_EN=300
DEEPGRAM_ENDPOINTING_CJK=500
# Per-language turn-end grace floor (ms) — combined with the per-style values above
# via max(); CJK answers (monologues) get more patience than English.
ENDPOINT_MIN_DELAY_EN=300
ENDPOINT_MAX_DELAY_EN=3000
ENDPOINT_MIN_DELAY_ZH=700
ENDPOINT_MAX_DELAY_ZH=4000
ENDPOINT_MIN_DELAY_JA=800
ENDPOINT_MAX_DELAY_JA=4000
ENDPOINT_MIN_DELAY_KO=800
ENDPOINT_MAX_DELAY_KO=4000
# Semantic end-of-turn (EOU) threshold, pinned per language (scalar applies to all
# detected languages — avoids relying on the STT-reported language, which can be
# null). Defaults mirror @livekit/agents LOCAL_LANGUAGES.
EOU_THRESHOLD_EN=0.36
EOU_THRESHOLD_ZH=0.355
EOU_THRESHOLD_JA=0.295
EOU_THRESHOLD_KO=0.4
# Korean TTS (Phase 4) is ElevenLabs (Cartesia has no Korean):
ELEVENLABS_MODEL=eleven_flash_v2_5

# ── Database ────────────────────────────────────────────────────────────────
# 'sqlite' (default) = durable on-disk file, zero setup, single host.
# 'postgres'        = Supabase / Neon / RDS — set DATABASE_URL below.
DB_PROVIDER=sqlite
# For Supabase: Project → Settings → Database → Connection string → URI.
# Use the SESSION pooler (port 5432) or the connection pooler (port 6543) and put
# your DB password in place of [YOUR-PASSWORD]. SSL is enabled automatically.
#   postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
# Supabase project URL + publishable (anon) key — used by the mobile client.
# Project → Settings → API. The publishable/anon key is safe to ship to clients.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ── Object storage (recordings / report exports) ── optional for local dev ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=viva-media

# ── Email (transactional — verification, report-ready notifications) ───────
# Resend API key (https://resend.com) + the verified From address.
RESEND_API_KEY=
EMAIL_FROM=viva <noreply@yourdomain.com>

# ── Auth (JWT signing for the app's own sessions) ──────────────────────────
JWT_SECRET=change-me-in-production

# ── Service config ──────────────────────────────────────────────────────────
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
NODE_ENV=development
# Comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:8081,http://localhost:19006
