# Copy to mobile/.env. Expo inlines EXPO_PUBLIC_* at build time.

# Backend API base URL.
#  - iOS Simulator / web on the Mac:  http://localhost:4000
#  - Real iPhone (Expo Go / dev build): your Mac's LAN IP, e.g. http://192.168.1.23:4000
#    (find it: System Settings → Wi-Fi → Details → IP address, or `ipconfig getifaddr en0`)
EXPO_PUBLIC_API_URL=http://localhost:4000

# Set to false to run the live-interview screens in UI-only demo mode (no backend/LiveKit).
EXPO_PUBLIC_LIVE_ENABLED=true
