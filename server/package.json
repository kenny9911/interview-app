{
  "name": "viva-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "viva backend \u2014 API, LiveKit token mint, multi-agent interview orchestration, analysis.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx scripts/calibration.ts",
    "db:check": "tsx scripts/dbHealthcheck.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@fastify/cors": "^11.0.1",
    "@types/pg": "^8.20.0",
    "fastify": "^5.6.1",
    "livekit-server-sdk": "^2.13.4",
    "pg": "^8.22.0",
    "pino": "^10.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "pg-mem": "^3.0.14",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
